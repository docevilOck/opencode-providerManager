{
  "name": "@docevilock/opencode-provider-manager",
  "version": "0.1.0",
  "type": "module",
  "description": "OpenCode TUI plugin for inspecting and managing providers and agent model bindings.",
  "main": "./dist/index.js",
  "exports": {
    ".": "./dist/index.js",
    "./tui": "./dist/index.js"
  },
  "files": [
    "dist",
    "README.md"
  ],
  "publishConfig": {
    "access": "public"
  },
  "scripts": {
    "clean": "node -e \"require('node:fs').rmSync('dist', { recursive: true, force: true })\"",
    "prebuild": "npm run clean",
    "prepack": "npm run build",
    "build": "tsc -p tsconfig.json",
    "test": "vitest run",
    "test:watch": "vitest"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/docevilOck/opencode-providerManager.git",
    "directory": "plugin"
  },
  "bugs": {
    "url": "https://github.com/docevilOck/opencode-providerManager/issues"
  },
  "homepage": "https://github.com/docevilOck/opencode-providerManager#readme",
  "keywords": [
    "opencode",
    "plugin",
    "tui",
    "provider",
    "agent"
  ],
  "devDependencies": {
    "@types/node": "^22.0.0",
    "typescript": "^5.6.0",
    "vitest": "^2.1.0"
  },
  "dependencies": {
    "@opentui/solid": "^0.2.15",
    "solid-js": "^1.9.13"
  }
}
